# PayTR iFrame API Bilgileri
# paytr.com/magaza/entegrasyon-bilgileri sayfasından alın
PAYTR_MERCHANT_ID=706553
PAYTR_MERCHANT_KEY=<merchant_key_buraya>
PAYTR_MERCHANT_SALT=<merchant_salt_buraya>
PAYTR_TEST_MODE=1          # Canlıya geçince 0 yapın

# Site base URL (callback için)
BASE_URL=https://requesthitbot.com

# CORS
ALLOWED_ORIGINS=https://requesthitbot.com

# İndirme dizini (varsayılan: server/downloads/)
# DOWNLOADS_DIR=/opt/requestbot/server/downloads

# Manuel ödeme (banka havalesi için, artık opsiyonel)
# PAYMENT_BANK=Papara
# PAYMENT_IBAN=TR...
# PAYMENT_NAME=RequestHitBot
